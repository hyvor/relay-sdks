{
    "name": "@hyvor/relay",
    "version": "0.1.0",
    "description": "Official JavaScript/TypeScript SDK for Hyvor Relay",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hyvor/relay-sdks.git",
        "directory": "js"
    },
    "homepage": "https://relay.hyvor.com",
    "keywords": [
        "hyvor",
        "relay",
        "email",
        "sdk",
        "transactional-email"
    ],
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@types/node": "^25.9.2",
        "@vitest/coverage-v8": "^4.1.8",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.8"
    }
}
